ETHERSCORE_HOST=127.0.0.1
ETHERSCORE_PORT=8000

# Required for multi-chain RPC.
ETHERSCORE_RPC_URL_ETHEREUM=
ETHERSCORE_RPC_URL_POLYGON=
ETHERSCORE_RPC_URL_BSC=
ETHERSCORE_RPC_URL_ARBITRUM=

# Optional legacy fallback for ethereum.
ETHERSCORE_RPC_URL=

# Optional NFT APIs by chain.
ETHERSCORE_NFT_API_URL_ETHEREUM=
ETHERSCORE_NFT_API_URL_POLYGON=
ETHERSCORE_NFT_API_URL_BSC=
ETHERSCORE_NFT_API_URL_ARBITRUM=

# Optional legacy NFT API fallback.
ETHERSCORE_NFT_API_URL=

# Optional ENS and price providers.
ETHERSCORE_ENS_API_URL=https://api.ensideas.com/ens/resolve
ETHERSCORE_ETH_PRICE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=ethereum,matic-network,binancecoin&vs_currencies=usd
ETHERSCORE_CREDIT_MODEL_DATASET_PATH=backend/credit_scoring_dataset.csv

# Optional ethereum account age fallback.
ETHERSCORE_ETHERSCAN_API_KEY=
ETHERSCORE_ETHERSCAN_API_URL=https://api.etherscan.io/api

# Security and ops.
ETHERSCORE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ETHERSCORE_RATE_LIMIT_PER_MINUTE=60
ETHERSCORE_RATE_LIMIT_WINDOW_SECONDS=60
ETHERSCORE_LOG_LEVEL=INFO

# Caching and upstream behavior.
ETHERSCORE_CACHE_TTL_SECONDS=120
ETHERSCORE_PRICE_CACHE_TTL_SECONDS=900
ETHERSCORE_REQUEST_TIMEOUT_SECONDS=10
ETHERSCORE_UPSTREAM_RETRY_COUNT=1
